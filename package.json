{
  "name": "screenlint",
  "version": "0.1.0",
  "description": "Lint what the browser actually rendered: a Playwright-powered UI QA gate for AI-built frontends.",
  "type": "module",
  "bin": {
    "screenlint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run test && npm run build",
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo --out reports/demo --fail-on never",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "playwright",
    "visual-testing",
    "ai-agents",
    "ui",
    "cli",
    "accessibility",
    "frontend",
    "vibe-coding"
  ],
  "author": "maxi-maxima",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1",
    "playwright": "^1.57.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  }
}
